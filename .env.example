# ============================================================================
# TMDB Configuration (REQUIRED)
# ============================================================================
# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ============================================================================
# Showbox/Febbox Configuration (Optional - for native streaming)
# ============================================================================
SHOWBOX_API_BASE=https://api.showbox.media
SHOWBOX_API_KEY=your_showbox_api_key

FEBBOX_API_BASE=https://www.febbox.com
FEBBOX_API_KEY=your_febbox_api_key

# ============================================================================
# Server Configuration
# ============================================================================
# Port (auto-set on Railway/Replit)
PORT=3000

# Environment: development or production
NODE_ENV=development

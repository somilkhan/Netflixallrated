# TMDB API Key (get free at https://www.themoviedb.org/settings/api)
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Showbox API Configuration
SHOWBOX_API_BASE=https://api.showbox.media
SHOWBOX_API_KEY=your_showbox_api_key

# Febbox API Configuration
FEBBOX_API_BASE=https://www.febbox.com
FEBBOX_API_KEY=your_febbox_api_key

# Server Port (Replit auto-sets this)
PORT=3000

# Environment
NODE_ENV=development

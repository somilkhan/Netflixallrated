# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TMDB_API_KEY: Optional/Required for live movie and TV show data from TMDB.
# If omitted, the app runs gracefully with high-quality cached fallback data.
TMDB_API_KEY=""

# SUPABASE_URL: Optional/Required for persistent cloud user authentication and history syncing.
# If omitted, the app runs in client-side LocalStorage mode automatically.
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Optional/Required for persistent cloud user authentication and history syncing.
SUPABASE_ANON_KEY=""

# NETMIRROR_API_KEY: Optional/Required key for the premium NetMirror stream provider.
NETMIRROR_API_KEY=""

# NETMIRROR_API_URL: Optional custom base URL for the NetMirror streaming API provider. Defaults to https://netmirror.one
NETMIRROR_API_URL="https://netmirror.one"


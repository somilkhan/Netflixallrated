# Base URL of the backend API service on Railway (no trailing slash, no /api suffix).
# Build-time only — Vite bakes this into the client bundle.
VITE_API_URL="https://your-server.up.railway.app/api"

# Supabase config (URL, anon key) is NOT needed here — the client fetches it
# from the backend's GET /api/config at runtime.

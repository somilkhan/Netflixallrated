DATABASE_URL="postgresql://user:password@localhost:5432/allrated?schema=public"
PORT=3000

# Comma-separated list of allowed frontend origins (Railway client URL,
# custom domain, etc). Must exactly match the origin the browser sends.
CLIENT_URL="https://your-client.up.railway.app"

# Supabase Auth (used to verify user JWTs, and exposed to the client via GET /api/config)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# TMDB (used by the admin panel to search/import real titles, and by the
# daily sync job). Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""
TMDB_API_BASE="https://api.themoviedb.org/3"
TMDB_IMAGE_BASE="https://image.tmdb.org/t/p"

# Optional: only needed if you also want an external scheduler (e.g.
# cron-job.org) to hit POST /api/titles/sync-batch as a fallback to the
# Railway scheduled service. Not required for the primary sync path.
CRON_SECRET=""

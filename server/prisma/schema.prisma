generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TitleType {
  MOVIE
  SERIES
  ANIME
}

enum Tier {
  SKIP
  TIMEPASS
  GOFORIT
  PERFECTION
}

enum WatchStatus {
  PLAN_TO_WATCH
  WATCHING
  COMPLETED
  DROPPED
}

enum Role {
  USER
  ADMIN
}

model User {
  id          String   @id              // Supabase Auth UUID — provided at creation, never auto-generated
  email       String   @unique
  displayName String?
  avatarUrl   String?
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratings         Rating[]
  watchlist       WatchlistItem[]
  watchProgress   WatchProgress[]
}

model Title {
  id               String    @id @default(uuid())
  name             String
  type             TitleType
  year             Int
  runtimeMinutes   Int?
  genres           String[]
  synopsis         String    @db.Text
  posterColorFrom  String
  posterColorTo    String
  trailerYoutubeId String?
  officialWatchLinks Json?   @db.Json
  tmdbId           Int?      @unique
  anilistId        Int?      @unique
  posterUrl        String?
  backdropUrl      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ratings        Rating[]
  watchlistItems WatchlistItem[]
  platforms      TitlePlatform[]
  watchProgress  WatchProgress[]
}

/// Continue Watching / Watch History — one row per user+title, updated on
/// every playback tick. Stores last-watched episode (for series/anime) and
/// the resume timestamp, synced across devices since it's server-backed.
model WatchProgress {
  id              String   @id @default(uuid())
  userId          String
  titleId         String
  seasonNumber    Int?
  episodeNumber   Int?
  episodeTitle    String?
  positionSeconds Int      @default(0)
  durationSeconds Int?
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@index([userId, updatedAt])
}

model Rating {
  id         String   @id @default(uuid())
  userId     String
  titleId    String
  tier       Tier
  reviewText String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@index([titleId])
}

model WatchlistItem {
  id        String      @id @default(uuid())
  userId    String
  titleId   String
  status    WatchStatus
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@index([userId])
}

model Platform {
  id      String  @id @default(uuid())
  name    String
  abbr    String  @unique
  iconUrl String?

  titles TitlePlatform[]
}

model TitlePlatform {
  titleId    String
  platformId String

  title    Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@id([titleId, platformId])
}

/// Generic key-value store — used for sync progress tracking and feature flags.
model KV {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

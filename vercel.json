{
  "version": 2,
  "buildCommand": "npm install -g yarn && cd server && yarn install && npx prisma generate && cd ../client && yarn install && yarn build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
